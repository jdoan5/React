# Copy this file to `.env` and fill in your key. `.env` is gitignored.

# Your massive.com API key (from https://massive.com/dashboard).
# Used ONLY server-side by the /api/massive proxy — never exposed to the browser.
MASSIVE_API_KEY=

# Optional: override the API host if your dashboard shows a different one.
MASSIVE_BASE_URL=https://api.massive.com
